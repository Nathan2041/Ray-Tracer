{
	"explorer.confirmDelete": false,
	"workbench.colorTheme": "One Dark Pro Darker",
	"editor.autoIndentOnPaste": true,
	"editor.tabSize": 2,
	"editor.stickyTabStops": true,
	"editor.insertSpaces": false,
	"html.format.indentInnerHtml": true,
	"editor.guides.indentation": true,
	"editor.renderWhitespace": "boundary",
	"editor.guides.highlightActiveIndentation": "always",
	"editor.fontFamily": "'JetBrains Mono', monospace",
	"editor.fontLigatures": true,
	"git.enableSmartCommit": true,

	"gitlens.codeLens.enabled": false,
	"gitlens.currentLine.enabled": true,
	"gitlens.hovers.enabled": false,
	"gitlens.statusBar.enabled": false,
	"workbench.sideBar.location": "right",
	"chat.commandCenter.enabled": false,
	"workbench.navigationControl.enabled": true,
	"editor.acceptSuggestionOnCommitCharacter": false,
	"workbench.commandPalette.preserveInput": true,
	"workbench.hover.reducedDelay": 250,
	"workbench.layoutControl.type": "both",
	"workbench.secondarySideBar.showLabels": false,
	"workbench.commandPalette.experimental.suggestCommands": true,
	"workbench.commandPalette.showAskInChat": false,
	"workbench.experimental.cloudChanges.autoStore": "onShutdown",
	"workbench.activityBar.compact": false,
	"workbench.activityBar.location": "default",
	"workbench.editor.decorations.colors": true,
	"workbench.iconTheme": "catppuccin-mocha",
	"workbench.preferredDarkColorTheme": "One Dark Pro Darker",
	"workbench.preferredLightColorTheme": "Atom One Light",
	"workbench.statusBar.visible": true,
	"workbench.tips.enabled": false,
	"workbench.view.alwaysShowHeaderActions": true,
	"chat.agent.maxRequests": 0,
	"chat.agent.enabled": false,
	"chat.checkpoints.enabled": false,
	"chat.customAgentInSubagent.enabled": false,
	"chat.agent.thinking.collapsedTools": "off",
	"chat.agent.thinking.generateTitles": false,
	"chat.agent.thinking.terminalTools": false
}